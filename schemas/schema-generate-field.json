              "enum": [
                "AutoNumber",
                "Checkbox",
                "Currency",
                "DateTime",
                "Date",
                "Email",
                "Html",
                "Location",
                "LongTextArea",
                "Lookup",
                "MasterDetail",
                "Number",
                "Phone",
                "Picklist",
                "Text",
                "Time",
                "Url"
              ]
            }
